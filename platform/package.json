{
  "name": "platform",
  "scripts": {
    "build": "pnpm dlx projen build",
    "compile": "pnpm dlx projen compile",
    "default": "pnpm dlx projen default",
    "eslint": "pnpm dlx projen eslint",
    "package": "pnpm dlx projen package",
    "post-compile": "pnpm dlx projen post-compile",
    "pre-compile": "pnpm dlx projen pre-compile",
    "test": "pnpm dlx projen test",
    "test:watch": "pnpm dlx projen test:watch",
    "watch": "pnpm dlx projen watch",
    "projen": "pnpm dlx projen",
    "start": "node --import @pipeline-builder/api-server/lib/otel-bootstrap.js lib/index.js",
    "docker:build": "pnpm nx run-many -t build --projects=platform --with-deps; rm -rf .docker-build; pnpm deploy --filter platform --prod --legacy .docker-build; docker buildx build --no-cache --pull --load --build-arg WORKSPACE=${WORKSPACE:-./} --secret id=npmrc,src=$(npm get userconfig) -t ${PROJECT_NAME:-platform}:$(jq -r .version package.json) .; status=$?; rm -rf .docker-build; exit $status",
    "docker:tag": "docker image tag ${PROJECT_NAME:-platform}:$(jq -r .version package.json) ${REGISTRY:-ghcr.io/mwashburn160}/${PROJECT_NAME:-platform}:$(jq -r .version package.json)",
    "docker:push": "docker push ${REGISTRY:-ghcr.io/mwashburn160}/${PROJECT_NAME:-platform}:$(jq -r .version package.json)"
  },
  "devDependencies": {
    "@jest/globals": "30.2.0",
    "@stylistic/eslint-plugin": "^2",
    "@types/adm-zip": "0.5.8",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/express-serve-static-core": "5.1.1",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.1.0",
    "@types/node": "25.9.2",
    "@types/nodemailer": "8.0.0",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "copyfiles": "2.4.1",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jest": "30.4.2",
    "jest-junit": "^17",
    "ts-jest": "^29",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "3.1064.0",
    "@pipeline-builder/api-core": "workspace:*",
    "@pipeline-builder/api-server": "workspace:*",
    "@pipeline-builder/pipeline-core": "workspace:*",
    "adm-zip": "0.5.17",
    "bcryptjs": "3.0.3",
    "cors": "2.8.6",
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.2.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.6.3",
    "multer": "2.1.1",
    "nodemailer": "8.0.10",
    "pg": "8.21.0",
    "prom-client": "15.1.3",
    "slugify": "1.6.9",
    "uuid": "14.0.0",
    "winston": "3.19.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "engines": {
    "node": ">= 24.14.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=10",
      "onFail": "ignore"
    }
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "version": "3.4.83",
  "packageManager": "pnpm@10.33.0",
  "jest": {
    "coverageProvider": "v8",
    "testMatch": [
      "<rootDir>/@(src|test)/**/*(*.)@(spec|test).ts?(x)",
      "<rootDir>/@(src|test)/**/__tests__/**/*.ts?(x)"
    ],
    "clearMocks": true,
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "lcov",
      "clover",
      "cobertura",
      "text"
    ],
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "watchPathIgnorePatterns": [
      "/node_modules/"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-reports"
        }
      ]
    ],
    "transform": {
      "^.+\\.[t]sx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.dev.json",
          "diagnostics": {
            "ignoreCodes": [
              151002
            ]
          }
        }
      ]
    },
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx"
    ],
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/../jest-uuid-stub.js",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "type": "module",
  "//": "~~ Generated by projen. To modify, edit .projenrc.js and run \"pnpm dlx projen\"."
}
