{
  "name": "@pipeline-builder/pipeline-data",
  "description": "Database layer for Pipeline Builder: Drizzle ORM schemas, connection management, query builders, and the generic CrudService base class with per-organization (and team) access control.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwashburn160/pipeline-builder.git"
  },
  "scripts": {
    "build": "pnpm dlx projen build",
    "compile": "pnpm dlx projen compile",
    "default": "pnpm dlx projen default",
    "eslint": "pnpm dlx projen eslint",
    "package": "pnpm dlx projen package",
    "post-compile": "pnpm dlx projen post-compile",
    "pre-compile": "pnpm dlx projen pre-compile",
    "test": "pnpm dlx projen test",
    "test:watch": "pnpm dlx projen test:watch",
    "watch": "pnpm dlx projen watch",
    "projen": "pnpm dlx projen"
  },
  "devDependencies": {
    "@jest/globals": "30.2.0",
    "@stylistic/eslint-plugin": "^2",
    "@types/node": "25.9.2",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "drizzle-kit": "0.31.10",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jest": "30.4.2",
    "jest-junit": "^17",
    "ts-jest": "^29",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@pipeline-builder/api-core": "workspace:*",
    "drizzle-orm": "0.45.2",
    "pg": "8.21.0"
  },
  "keywords": [
    "ci-cd",
    "cicd",
    "continuous-delivery",
    "devops",
    "self-service",
    "platform-engineering",
    "internal-developer-platform",
    "developer-platform",
    "aws",
    "aws-cdk",
    "cdk",
    "codepipeline",
    "codebuild",
    "cloudformation",
    "pipeline",
    "pipeline-as-code",
    "infrastructure-as-code",
    "iac",
    "compliance",
    "policy-as-code",
    "governance",
    "golden-paths",
    "multi-tenant",
    "rbac",
    "ai",
    "ai-pipeline-generation",
    "llm",
    "bedrock",
    "plugins",
    "plugin-marketplace",
    "containerized",
    "docker",
    "kubernetes",
    "typescript",
    "cli"
  ],
  "engines": {
    "node": ">= 24.14.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=10",
      "onFail": "ignore"
    }
  },
  "main": "lib/index.js",
  "license": "Apache-2.0",
  "homepage": "https://mwashburn160.github.io/pipeline-builder/",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "version": "3.4.82",
  "bugs": {
    "url": "https://github.com/mwashburn160/pipeline-builder/issues"
  },
  "packageManager": "pnpm@10.33.0",
  "jest": {
    "coverageProvider": "v8",
    "testMatch": [
      "<rootDir>/@(src|test)/**/*(*.)@(spec|test).ts?(x)",
      "<rootDir>/@(src|test)/**/__tests__/**/*.ts?(x)"
    ],
    "clearMocks": true,
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "lcov",
      "clover",
      "cobertura",
      "text"
    ],
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "watchPathIgnorePatterns": [
      "/node_modules/"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-reports"
        }
      ]
    ],
    "transform": {
      "^.+\\.[t]sx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.dev.json",
          "diagnostics": {
            "ignoreCodes": [
              151002
            ]
          }
        }
      ]
    },
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx"
    ],
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/../../jest-uuid-stub.js",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "types": "lib/index.d.ts",
  "type": "module",
  "//": "~~ Generated by projen. To modify, edit .projenrc.js and run \"pnpm dlx projen\"."
}
