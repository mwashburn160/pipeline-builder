{
  "name": "frontend",
  "scripts": {
    "build": "pnpm dlx projen build",
    "compile": "pnpm dlx projen compile",
    "default": "pnpm dlx projen default",
    "dev": "pnpm dlx projen dev",
    "export": "pnpm dlx projen export",
    "package": "pnpm dlx projen package",
    "post-compile": "pnpm dlx projen post-compile",
    "pre-compile": "pnpm dlx projen pre-compile",
    "server": "pnpm dlx projen server",
    "telemetry": "pnpm dlx projen telemetry",
    "test": "pnpm dlx projen test",
    "test:watch": "pnpm dlx projen test:watch",
    "projen": "pnpm dlx projen",
    "start": "node lib/index.js",
    "docker:build": "docker buildx build --no-cache --pull --load --build-arg WORKSPACE=${WORKSPACE:-./} --secret id=npmrc,src=$(npm get userconfig) -t ${PROJECT_NAME:-frontend}:$(jq -r .version package.json) .",
    "docker:tag": "docker image tag ${PROJECT_NAME:-frontend}:$(jq -r .version package.json) ${REGISTRY:-ghcr.io/mwashburn160}/${PROJECT_NAME:-frontend}:$(jq -r .version package.json)",
    "docker:push": "docker push ${REGISTRY:-ghcr.io/mwashburn160}/${PROJECT_NAME:-frontend}:$(jq -r .version package.json)"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.24",
    "jest": "^30.2.0",
    "jest-junit": "^16",
    "postcss": "8.5.6",
    "ts-jest": "^29.4.6",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@mwashburn160/api-core": "1.45.3",
    "@mwashburn160/api-server": "1.42.8",
    "@mwashburn160/pipeline-core": "1.46.3",
    "framer-motion": "12.34.3",
    "lucide-react": "0.575.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "swr": "2.3.3",
    "tailwindcss": "4.2.1"
  },
  "engines": {
    "node": ">= 24.14.0"
  },
  "main": "lib/index.js",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.0",
  "jest": {
    "coverageProvider": "v8",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/test/**/*.test.ts"
    ],
    "clearMocks": true,
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "lcov",
      "clover",
      "cobertura",
      "text"
    ],
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "watchPathIgnorePatterns": [
      "/node_modules/"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-reports"
        }
      ]
    ],
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/../../jest-uuid-stub.js",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  },
  "//": "~~ Generated by projen. To modify, edit .projenrc.js and run \"pnpm dlx projen\"."
}
