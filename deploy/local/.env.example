# ============================================================================
# Pipeline Manager - Environment Configuration
# ============================================================================
# Copy to .env and fill in secret values. Generate JWT secrets with: openssl rand -base64 32
# IMPORTANT: Never commit .env file to version control!
# Add .env to .gitignore
# ============================================================================

# ============================================================================
# Platform Configuration
# ============================================================================

# Platform URL - Used by services to reference the API gateway
# Used by CLI when PLATFORM_BASE_URL environment variable is not set
PLATFORM_BASE_URL=https://localhost:8443

# Frontend URL - Used for email links, OAuth redirects, etc.
PLATFORM_FRONTEND_URL=https://localhost:8443

# Service port (used by platform, quota, pipeline-core)
PORT=3000

# Trust proxy headers (behind load balancer)
# Set to 1 if behind nginx, ALB, etc.
TRUST_PROXY=1

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (error | warn | info | debug)
LOG_LEVEL=info

# Log format: 'json' for structured JSON (used by Loki), 'text' for human-readable
LOG_FORMAT=json

# Service name used in log output
SERVICE_NAME=api

# ============================================================================
# Grafana Configuration (Observability)
# ============================================================================

# Grafana admin credentials (local dev only)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ============================================================================
# CORS Configuration
# ============================================================================

# Allow credentials in CORS requests (true | false)
CORS_CREDENTIALS=true

# Allowed CORS origins (comma-separated, leave empty for default)
# Example: https://localhost:3000,https://app.example.com
CORS_ORIGIN=

# ============================================================================
# JWT Configuration (REQUIRED)
# ============================================================================

# JWT Secret - Used to sign and verify PLATFORM_TOKEN
# SECURITY: Generate a strong random secret (32+ characters)
# Example: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# JWT Token expiration (in seconds)
# 900 = 15 minutes, 3600 = 1 hour, 86400 = 24 hours
JWT_EXPIRES_IN=7200

# JWT signing algorithm (HS256 | HS384 | HS512 | RS256)
JWT_ALGORITHM=HS256

# JWT Salt rounds for bcrypt
# Higher = more secure but slower (10-12 recommended)
JWT_SALT_ROUNDS=12

# Refresh Token Secret - Separate secret for refresh tokens
# SECURITY: Generate a different secret from JWT_SECRET
REFRESH_TOKEN_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# Refresh Token expiration (in seconds)
# 2592000 = 30 days
REFRESH_TOKEN_EXPIRES_IN=2592000

# ============================================================================
# Security Configuration
# ============================================================================

# Minimum password length (code uses PASSWORD_MIN_LENGTH, default: 8)
PASSWORD_MIN_LENGTH=12

# Maximum login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# ============================================================================
# Google OAuth Configuration (Optional)
# ============================================================================
# Enables "Continue with Google" on login/register pages.
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${PLATFORM_FRONTEND_URL}/auth/callback/google

# Google OAuth Client ID (leave empty to disable)
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth callback base URL (defaults to PLATFORM_FRONTEND_URL if not set)
# Only override if your frontend URL differs from the OAuth redirect origin
OAUTH_CALLBACK_BASE_URL=${PLATFORM_FRONTEND_URL}

# OAuth CSRF state token TTL in milliseconds (default: 600000 = 10 minutes)
# OAUTH_STATE_TTL_MS=600000

# ============================================================================
# Quota Tier Defaults (Quota Service)
# ============================================================================
# Tier presets are defined in code (platform config + quota-helpers).
# These env vars set the quota service's *fallback* defaults for orgs
# that don't yet have a tier assigned.
#
# Tier presets (hardcoded in platform/src/config and quota-helpers):
#   developer: plugins=100, pipelines=10, apiCalls=-1, reset=3days
#   pro:       plugins=1000, pipelines=100, apiCalls=-1, reset=3days
#   unlimited: plugins=-1, pipelines=-1, apiCalls=-1, reset=30days
#
# These values match the "developer" tier (the default for new orgs).
QUOTA_DEFAULT_PLUGINS=100
QUOTA_DEFAULT_PIPELINES=10
QUOTA_DEFAULT_API_CALLS=-1
QUOTA_RESET_DAYS=3

# ============================================================================
# Quota Service Configuration
# ============================================================================
# Internal service discovery for quota enforcement
# Used by: plugin, pipeline services

# Quota service hostname (Docker service name)
QUOTA_SERVICE_HOST=quota

# Quota service port
QUOTA_SERVICE_PORT=3000

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
# Per-organization rate limits for API operations
# Set to 'unlimited' to disable rate limiting for an operation

# Organization ID that bypasses all quotas (typically 'system')
QUOTA_BYPASS_ORG_ID=system

# Default rate limit window in milliseconds (60000 = 60 seconds)
QUOTA_DEFAULT_WINDOW_MS=60000

# Quota service rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Plugin rate limits
# Create plugin: requests per window (set to 'unlimited' for no limit)
QUOTA_CREATE_PLUGIN_LIMIT=unlimited
QUOTA_CREATE_PLUGIN_WINDOW_MS=60000

# Get plugin by ID: requests per window
QUOTA_GET_PLUGIN_LIMIT=10
QUOTA_GET_PLUGIN_WINDOW_MS=60000

# Pipeline rate limits
# Create pipeline: requests per window (set to 'unlimited' for no limit)
QUOTA_CREATE_PIPELINE_LIMIT=unlimited
QUOTA_CREATE_PIPELINE_WINDOW_MS=60000

# Get pipeline by ID: requests per window
QUOTA_GET_PIPELINE_LIMIT=10
QUOTA_GET_PIPELINE_WINDOW_MS=60000

# ============================================================================
# Global Rate Limiting
# ============================================================================
# Applied to all API requests (independent of quota middleware)

# Maximum requests per window
LIMITER_MAX=100

# Rate limit window in milliseconds (900000 = 15 minutes)
LIMITER_WINDOWMS=900000

# ============================================================================
# Email Configuration
# ============================================================================

# Enable/disable email sending
EMAIL_ENABLED=false

# Sender information
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=pipeline-builder

# Email provider (smtp | ses)
EMAIL_PROVIDER=smtp

# SMTP Configuration
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# AWS SES Configuration (used when EMAIL_PROVIDER=ses)
SES_REGION=us-east-1
SES_ACCESS_KEY_ID=your-aws-access-key-id
SES_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# ============================================================================
# Invitation Configuration
# ============================================================================

# Invitation expiration (in days)
INVITATION_EXPIRATION_DAYS=7

# Maximum pending invitations per organization
INVITATION_MAX_PENDING_PER_ORG=50

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================

# PostgreSQL connection details
# Used by: postgres container, pipeline, plugin services
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=pipeline_builder

# Database connection for services (should match POSTGRES_* values)
DB_HOST=postgres
DB_PORT=5432
DATABASE=pipeline_builder
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# Drizzle ORM Configuration
DRIZZLE_MAX_POOL_SIZE=20
DRIZZLE_IDLE_TIMEOUT_MILLIS=30000
# Connection timeout: pipeline-data defaults 10000, pipeline-core defaults 5000
DRIZZLE_CONNECTION_TIMEOUT_MILLIS=10000

# ============================================================================
# MongoDB Configuration
# ============================================================================

# MongoDB Admin Credentials
# Used by: platform, quota services
MONGO_INITDB_ROOT_USERNAME=mongo
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME
MONGO_INITDB_DATABASE=platform

# MongoDB Connection URI (Replica Set)
# Format: mongodb://username:password@host:port/database?options
# Used by: platform, quota services
MONGODB_URI='mongodb://mongo:CHANGE_ME@mongodb:27017/platform?replicaSet=rs0&authSource=admin'

# ============================================================================
# Mongo Express (MongoDB Admin UI)
# ============================================================================

# Mongo Express Configuration
# Access at: http://localhost:27081 or https://localhost:8443/mongo-express/
ME_CONFIG_SITE_BASEURL=/mongo-express/
ME_CONFIG_MONGODB_URL='mongodb://mongo:CHANGE_ME@mongodb:27017/platform?replicaSet=rs0&authSource=admin'
ME_CONFIG_MONGODB_ENABLE_ADMIN=true
ME_CONFIG_MONGODB_ADMINUSERNAME=mongo
ME_CONFIG_MONGODB_ADMINPASSWORD=CHANGE_ME

# Mongo Express Web Authentication
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=CHANGE_ME

# ============================================================================
# PgAdmin (PostgreSQL Admin UI)
# ============================================================================

# PgAdmin Configuration
# Access at: http://localhost:5480 or https://localhost:8443/pgadmin/
PGADMIN_DEFAULT_EMAIL=admin@pipeline.dev
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME

# ============================================================================
# Docker Registry Configuration
# ============================================================================

# Docker Registry for Plugin Images
# Used by: plugin service
IMAGE_REGISTRY_HOST=registry
IMAGE_REGISTRY_PORT=5000
IMAGE_REGISTRY_USER=admin
IMAGE_REGISTRY_TOKEN=CHANGE_ME

# Docker socket GID — docker-compose mounts /var/run/docker.sock into the
# plugin service container to build plugin images. Set this to the GID of
# the docker group on your host so the container has permission to use it:
#   macOS:  stat -f '%g' /var/run/docker.sock
#   Linux:  stat -c '%g' /var/run/docker.sock
# Note: k8s deployments (minikube, ec2) use a docker:dind sidecar instead
# and do not need this variable.
DOCKER_GID=0

# Docker network for plugin builds — the buildx builder container network mode.
# 'host' shares the dind container's network namespace, which is on the compose
# network and can resolve both internal services (registry) and external hosts.
DOCKER_NETWORK=host

# Use plain HTTP for registry push (default: true).
# Set 'false' when the registry uses TLS (even self-signed).
DOCKER_REGISTRY_HTTP=false

# Skip TLS certificate verification (default: true).
# Set 'false' for production registries with valid CA certs.
# DOCKER_REGISTRY_INSECURE=false

# Shared temp directory for Docker builds. Must use the SAME absolute path
# on both host and container so buildkitd.toml bind mounts resolve.
# Defaults to $DEPLOY_DIR/data/plugin-builds (set by startup.sh).
# DOCKER_BUILD_TEMP_ROOT=/custom/path

# ============================================================================
# Redis Configuration (Job Queue)
# ============================================================================
# Used by: plugin service (BullMQ job queue for Docker builds)

# Code defaults to 'localhost' when unset; use 'redis' for Docker Compose
REDIS_HOST=redis
REDIS_PORT=6379

# Max concurrent Docker plugin builds (BullMQ worker concurrency)
# Set to match the number of plugin service replicas/containers
PLUGIN_BUILD_CONCURRENCY=1

# ============================================================================
# Registry UI (Docker Registry Web Interface)
# ============================================================================

# Joxit Docker Registry UI Configuration
# Access at: http://localhost:5080 or https://localhost:8443/registry-express/
JOXIT_REGISTRY_TITLE="Pipeline Builder Registry"
JOXIT_NGINX_PROXY_PASS_URL=https://registry:5000
JOXIT_SINGLE_REGISTRY=true
JOXIT_ENABLE_DELETE_IMAGES=true
JOXIT_SHOW_CONTENT_DIGEST=true

# ============================================================================
# Loki Configuration (Log Aggregation)
# ============================================================================

# Loki URL for log queries (used by platform service)
LOKI_URL=http://loki:3100

# Loki HTTP request timeout in milliseconds (default: 10000)
# LOKI_TIMEOUT=10000

# ============================================================================
# Billing Configuration
# ============================================================================

# Enable/disable billing service (true | false)
# Code defaults to 'true'; set 'false' for local dev to disable billing routes
BILLING_ENABLED=false

# Billing service hostname (Docker service name)
BILLING_SERVICE_HOST=billing

# Billing service port
BILLING_SERVICE_PORT=3000

# Billing provider selection (stub | aws-marketplace | stripe)
# Use 'stub' for local development (no-op provider)
BILLING_PROVIDER=stub

# AWS Marketplace config (only needed when BILLING_PROVIDER=aws-marketplace)
AWS_MARKETPLACE_PRODUCT_CODE=
AWS_MARKETPLACE_REGION=us-east-1
AWS_MARKETPLACE_SNS_TOPIC_ARN=
AWS_MARKETPLACE_DIMENSION_MAP=

# Stripe config (only needed when BILLING_PROVIDER=stripe)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MAP={"developer_monthly":"price_xxx","developer_annual":"price_xxx","pro_monthly":"price_xxx","pro_annual":"price_xxx","unlimited_monthly":"price_xxx","unlimited_annual":"price_xxx"}

# ============================================================================
# Billing Plan Pricing (in cents)
# ============================================================================
# Override default plan prices per environment.
# Defaults match the standard tier pricing.

# Developer plan (free tier)
BILLING_PLAN_DEVELOPER_MONTHLY=0
BILLING_PLAN_DEVELOPER_ANNUAL=0

# Pro plan
BILLING_PLAN_PRO_MONTHLY=799
BILLING_PLAN_PRO_ANNUAL=7990

# Unlimited plan
BILLING_PLAN_UNLIMITED_MONTHLY=1199
BILLING_PLAN_UNLIMITED_ANNUAL=11990

# Plan descriptions (optional overrides)
# BILLING_PLAN_DEVELOPER_DESCRIPTION=Free starter tier for individual developers
# BILLING_PLAN_PRO_DESCRIPTION=For teams and production workloads
# BILLING_PLAN_UNLIMITED_DESCRIPTION=No restrictions for enterprise teams

# Plan features (optional JSON array overrides)
# BILLING_PLAN_DEVELOPER_FEATURES=["Up to 100 plugins","Up to 10 pipelines","Unlimited API calls","Community support"]
# BILLING_PLAN_PRO_FEATURES=["Up to 1,000 plugins","Up to 100 pipelines","Unlimited API calls","Community support","Reporting dashboard"]
# BILLING_PLAN_UNLIMITED_FEATURES=["Unlimited plugins","Unlimited pipelines","Unlimited API calls","Priority support","Reporting dashboard","Custom integrations"]

# ============================================================================
# Internal Service URLs (Platform Service Discovery)
# ============================================================================
# URLs used by the platform service to route to microservices
# In Docker Compose these typically point to the gateway

LIST_PLUGINS_URL=https://localhost:8443
GET_PLUGIN_URL=https://localhost:8443
UPLOAD_PLUGIN_URL=https://localhost:8443
LIST_PIPELINES_URL=https://localhost:8443
GET_PIPELINE_URL=https://localhost:8443
CREATE_PIPELINE_URL=https://localhost:8443

# Internal service HTTP timeout (milliseconds)
SERVICE_TIMEOUT=30000

# Handler timeout (milliseconds): api-server defaults 30000, pipeline-core defaults 25000
HANDLER_TIMEOUT_MS=30000

# ============================================================================
# Message Routing
# ============================================================================
# Comma-separated email-like aliases that resolve to the system org
SUPPORT_ALIASES=support@pipeline-builder,help@pipeline-builder

# ============================================================================
# AWS CDK / Lambda Configuration
# ============================================================================
# Used by pipeline-core for CDK infrastructure builds

# Lambda runtime version
LAMBDA_RUNTIME=nodejs24.x

# Lambda timeout in seconds (max 900 = 15 minutes)
LAMBDA_TIMEOUT=900

# Lambda memory size in MB
LAMBDA_MEMORY_SIZE=128

# Lambda architecture (ARM_64 | x86_64)
LAMBDA_ARCHITECTURE=ARM_64

# ============================================================================
# AWS CloudWatch / CodeBuild Configuration
# ============================================================================

# CloudWatch log group name
LOG_GROUP_NAME=/pipeline-builder/logs

# Log retention in days (1, 3, 5, 7, 14, 30, 60, 90, etc.)
LOG_RETENTION=1

# Log removal policy (DESTROY | RETAIN)
LOG_REMOVAL_POLICY=DESTROY

# CodeBuild compute type (SMALL | MEDIUM | LARGE | X2_LARGE)
CODEBUILD_COMPUTE_TYPE=SMALL

# ============================================================================
# HTTP Client Configuration
# ============================================================================
# Used by: api-core internal HTTP client for service-to-service communication

# HTTP client timeout in milliseconds (default: 5000)
# HTTP_CLIENT_TIMEOUT=5000

# Maximum retry attempts for failed HTTP requests (default: 2)
# HTTP_CLIENT_MAX_RETRIES=2

# Delay between retries in milliseconds (default: 200)
# HTTP_CLIENT_RETRY_DELAY_MS=200

# ============================================================================
# SSE (Server-Sent Events) Configuration
# ============================================================================
# Used by: api-server SSE connection manager

# Maximum SSE clients per request (default: 10)
# SSE_MAX_CLIENTS_PER_REQUEST=10

# SSE client timeout in milliseconds (default: 1800000 = 30 minutes)
# SSE_CLIENT_TIMEOUT_MS=1800000

# SSE cleanup interval in milliseconds (default: 300000 = 5 minutes)
# SSE_CLEANUP_INTERVAL_MS=300000

# ============================================================================
# Plugin Build Queue Configuration
# ============================================================================
# Used by: plugin service BullMQ job queue

# Queue name for plugin builds (default: plugin-build)
# PLUGIN_BUILD_QUEUE_NAME=plugin-build

# Maximum build attempts before failing (default: 2)
# PLUGIN_BUILD_MAX_ATTEMPTS=2

# Exponential backoff delay in milliseconds (default: 5000)
# PLUGIN_BUILD_BACKOFF_DELAY_MS=5000

# Completed job retention in seconds (default: 3600 = 1 hour)
# PLUGIN_BUILD_COMPLETED_RETENTION_SECS=3600

# Failed job retention in seconds (default: 86400 = 24 hours)
# PLUGIN_BUILD_FAILED_RETENTION_SECS=86400

# Worker ready timeout in milliseconds (default: 10000)
# PLUGIN_BUILD_WORKER_TIMEOUT_MS=10000

# ============================================================================
# Docker Build Configuration
# ============================================================================
# Used by: plugin service for building plugin Docker images

# Docker build timeout in milliseconds (default: 900000 = 15 minutes)
DOCKER_BUILD_TIMEOUT_MS=900000

# Docker buildx builder name (default: plugin-builder)
# DOCKER_BUILDER_NAME=plugin-builder

# Plugin image tag prefix (default: p-)
# PLUGIN_IMAGE_PREFIX=p-

# ============================================================================
# Pagination & Limits
# ============================================================================
# Used by: api-core validation, pipeline-core, platform controllers

# Maximum page limit for paginated queries (default: 1000)
# MAX_PAGE_LIMIT=1000

# Default page limit when not specified (default: 100)
# DEFAULT_PAGE_LIMIT=100

# Maximum AI prompt length in characters (default: 5000)
# MAX_PROMPT_LENGTH=5000

# Maximum plugin upload size in bytes (default: 104857600 = 100MB)
# MAX_PLUGIN_UPLOAD_BYTES=104857600

# Maximum pipeline name length (default: 100)
# PIPELINE_NAME_MAX_LENGTH=100

# Default plugin version when not specified (default: 1.0.0)
# DEFAULT_PLUGIN_VERSION=1.0.0

# ============================================================================
# Database Connection Retries
# ============================================================================
# Used by: pipeline-data PostgreSQL connection manager

# Maximum connection retry attempts (default: 3)
# DB_MAX_RETRIES=3

# Delay between connection retries in milliseconds (default: 1000)
# DB_RETRY_DELAY_MS=1000

# ============================================================================
# Cookie Configuration
# ============================================================================
# Used by: platform authentication controllers

# SameSite cookie attribute (lax | strict | none)
# COOKIE_SAME_SITE=lax

# ============================================================================
# Google OAuth URL Overrides
# ============================================================================
# Override default Google OAuth endpoints (useful for custom OAuth providers)

# GOOGLE_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
# GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
# GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v2/userinfo

# OAuth CSRF state cleanup interval in milliseconds (default: 60000)
# OAUTH_CLEANUP_INTERVAL_MS=60000

# ============================================================================
# Platform Log & Pagination Defaults
# ============================================================================
# Used by: platform log service and list controllers

# Default log query limit (default: 100)
# LOG_DEFAULT_LIMIT=100

# Maximum log query limit (default: 1000)
# LOG_MAX_LIMIT=1000

# Default log lookback window in milliseconds (default: 3600000 = 1 hour)
# LOG_DEFAULT_LOOKBACK_MS=3600000

# Platform list endpoints max items (default: 100)
# PLATFORM_LIST_MAX=100

# Platform list endpoints default items (default: 20)
# PLATFORM_LIST_DEFAULT=20

# ============================================================================
# AI / LLM Configuration
# ============================================================================
# Ollama (Local LLM - default, no API key needed)
# After first start, pull a model: docker exec ollama ollama pull llama3
OLLAMA_BASE_URL=http://ollama:11434/v1

# Cloud AI providers (optional - uncomment to enable)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key
# XAI_API_KEY=your-xai-api-key

# ============================================================================
# Git URL Analysis Configuration
# ============================================================================
# Used by: pipeline service for Git URL-based pipeline generation

# GitHub REST API base URL (override for GitHub Enterprise)
# GITHUB_API_BASE_URL=https://api.github.com

# Bitbucket REST API base URL (override for Bitbucket Server)
# BITBUCKET_API_BASE_URL=https://api.bitbucket.org/2.0

# ============================================================================
# AI Generation SSE Configuration
# ============================================================================
# Used by: pipeline, plugin services for AI streaming generation

# SSE stream timeout in milliseconds (default: 300000 = 5 minutes)
# SSE_STREAM_TIMEOUT_MS=300000

# ============================================================================
# Plugin Service Discovery (for auto-plugin creation)
# ============================================================================
# Used by: pipeline service to call plugin service for auto-creating missing plugins

# Plugin service hostname (Docker service name)
PLUGIN_SERVICE_HOST=plugin

# Plugin service port
PLUGIN_SERVICE_PORT=3000

# ============================================================================
# Plugin Build Temp Directory
# ============================================================================
# Used by: plugin service temp directory cleanup

# Maximum age for temp build dirs before cleanup in ms (default: 3600000 = 1 hour)
# TEMP_DIR_MAX_AGE_MS=3600000

# ============================================================================
# Additional Configuration (not set by default)
# ============================================================================

# PLUGIN_MAX_UPLOAD_MB=50
# DOCKER_REGISTRY_INSECURE=false
# AUTH_LIMITER_MAX=5
# AUTH_LIMITER_WINDOWMS=900000
# BILLING_SERVICE_TIMEOUT=30000
# QUOTA_SERVICE_TIMEOUT=30000
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# =============================================================================
# Reporting & Audit
# =============================================================================
# AUDIT_RETENTION_DAYS=90
# EVENT_RETENTION_DAYS=90

# =============================================================================
# Response Compression
# =============================================================================
# Minimum response size in bytes before gzip compression is applied (default: 1024)
# COMPRESSION_THRESHOLD_BYTES=1024

# =============================================================================
# Idempotency Configuration
# =============================================================================
# TTL for cached idempotent responses in milliseconds (default: 300000 = 5 minutes)
# IDEMPOTENCY_TTL_MS=300000

# Maximum number of idempotent responses stored in memory (default: 10000)
# IDEMPOTENCY_MAX_STORE_SIZE=10000

# Cleanup interval for expired idempotency entries in ms (default: 60000 = 1 minute)
# IDEMPOTENCY_CLEANUP_INTERVAL_MS=60000

# =============================================================================
# Cache Configuration
# =============================================================================
# In-memory cache cleanup interval in milliseconds (default: 30000 = 30 seconds)
# CACHE_CLEANUP_INTERVAL_MS=30000

# =============================================================================
# SSE Backpressure
# =============================================================================
# Number of consecutive write failures before disconnecting slow SSE clients (default: 10)
# SSE_BACKPRESSURE_THRESHOLD=10

# =============================================================================
# HTTP Cache-Control Headers
# =============================================================================
# Cache-Control header for list/filter endpoints (default: private, max-age=30, stale-while-revalidate=60)
# CACHE_CONTROL_LIST=private, max-age=30, stale-while-revalidate=60

# Cache-Control header for detail endpoints (default: private, max-age=60, stale-while-revalidate=120)
# CACHE_CONTROL_DETAIL=private, max-age=60, stale-while-revalidate=120

# =============================================================================
# OpenTelemetry Tracing
# =============================================================================
# Enable OpenTelemetry distributed tracing (default: false)
# OTEL_TRACING_ENABLED=true

# OTLP exporter endpoint (default: http://localhost:4318/v1/traces)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
