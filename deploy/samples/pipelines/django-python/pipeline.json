{
  "project": "django",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for django-ve/django-helloworld - a minimal Django (Python) hello-world app. Includes testing, linting, and security scanning.",
  "keywords": [
    "python",
    "django",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "django",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "django-ve/django-helloworld",
          "branch": "master",
          "trigger": "NONE"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Test",
        "alias": "UnitTests",
        "steps": [
          {
            "plugin": {
              "name": "python-pytest",
              "filter": {
                "name": "python-pytest",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "PYTHON_VERSION": "3.12",
                "DJANGO_SETTINGS_MODULE": "helloworld.settings"
              }
            },
            "position": "pre",
            "timeout": 30
          },
          {
            "plugin": {
              "name": "coverage-py",
              "filter": {
                "name": "coverage-py",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "PYTHON_VERSION": "3.12",
                "COVERAGE_THRESHOLD": "75"
              }
            },
            "position": "post"
          }
        ]
      },
      {
        "stageName": "Lint",
        "alias": "CodeQuality",
        "steps": [
          {
            "plugin": {
              "name": "ruff",
              "filter": {
                "name": "ruff",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "PYTHON_VERSION": "3.12"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "mypy",
              "filter": {
                "name": "mypy",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "PYTHON_VERSION": "3.12"
              }
            },
            "position": "post",
            "failureBehavior": "warn"
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "bandit",
              "filter": {
                "name": "bandit",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "PYTHON_VERSION": "3.12",
                "BANDIT_SEVERITY": "medium"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post"
          }
        ]
      }
    ]
  }
}
