{
  "project": "django",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for django-ve/django-helloworld - a minimal Django (Python) hello-world app. Includes security scanning (SAST + secret detection).",
  "keywords": [
    "python",
    "django",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "django",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "django-ve/django-helloworld",
          "branch": "master",
          "trigger": "NONE"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "bandit",
              "filter": {
                "name": "bandit",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "PYTHON_VERSION": "3.12",
                "BANDIT_SEVERITY": "medium"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post"
          }
        ]
      }
    ]
  }
}
