{
  "project": "axum",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for tokio-rs/axum - an ergonomic and modular web framework built with Tokio, Tower, and Hyper. Includes building, testing, linting, security auditing, and crate publishing.",
  "keywords": [
    "rust",
    "axum",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "axum",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "tokio-rs/axum",
          "branch": "main",
          "trigger": "AUTO"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "alias": "BuildAndPackage",
        "steps": [
          {
            "plugin": {
              "name": "rust",
              "filter": {
                "name": "rust",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUST_VERSION": "stable",
                "CARGO_PROFILE": "release",
                "TARGET": "x86_64-unknown-linux-gnu",
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 30,
            "commands": [
              "cargo build --release --all-features"
            ]
          }
        ]
      },
      {
        "stageName": "Test",
        "alias": "UnitTests",
        "steps": [
          {
            "plugin": {
              "name": "cargo-test",
              "filter": {
                "name": "cargo-test",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUST_VERSION": "stable",
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 30,
            "commands": [
              "cargo test --all-features --workspace"
            ]
          }
        ]
      },
      {
        "stageName": "Lint",
        "alias": "CodeQuality",
        "steps": [
          {
            "plugin": {
              "name": "clippy",
              "filter": {
                "name": "clippy",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUST_VERSION": "stable",
                "CLIPPY_FLAGS": "-D warnings"
              }
            },
            "position": "pre",
            "commands": [
              "cargo clippy --all-targets --all-features -- -D warnings"
            ]
          },
          {
            "plugin": {
              "name": "rustfmt",
              "filter": {
                "name": "rustfmt",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUST_VERSION": "nightly"
              }
            },
            "position": "post",
            "commands": [
              "cargo +nightly fmt --all -- --check"
            ]
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "cargo-audit",
              "filter": {
                "name": "cargo-audit",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUST_VERSION": "stable"
              }
            },
            "position": "pre",
            "commands": [
              "cargo install cargo-audit",
              "cargo audit"
            ]
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post",
            "commands": [
              "git secrets --scan"
            ]
          }
        ]
      },
      {
        "stageName": "Package",
        "alias": "PackageImage",
        "steps": [
          {
            "plugin": {
              "name": "docker-build",
              "filter": {
                "name": "docker-build",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "IMAGE_NAME": "axum-acmecorp",
                "IMAGE_TAG": "latest",
                "REGISTRY_TYPE": "none",
                "aws:cdk:codebuild:buildenvironment:privileged": true,
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 20,
            "additionalInputArtifacts": [
              {
                "artifact": {
                  "stageName": "Build",
                  "stageAlias": "BuildAndPackage",
                  "pluginName": "rust",
                  "pluginAlias": "rust",
                  "outputDirectory": "**/*"
                },
                "directory": "build-artifact"
              }
            ]
          }
        ]
      }
    ]
  }
}
