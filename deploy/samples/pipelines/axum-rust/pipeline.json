{
  "project": "axum",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for ChiefTechDev/Rust-Axum-Hello-World - a minimal Axum (Rust) hello-world web app. Includes building, testing, linting, and security auditing.",
  "keywords": [
    "rust",
    "axum",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "axum",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "ChiefTechDev/Rust-Axum-Hello-World",
          "branch": "main",
          "trigger": "NONE"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "alias": "BuildAndPackage",
        "steps": [
          {
            "plugin": {
              "name": "rust",
              "filter": {
                "name": "rust",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUST_VERSION": "stable",
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 30
          }
        ]
      },
      {
        "stageName": "Test",
        "alias": "UnitTests",
        "steps": [
          {
            "plugin": {
              "name": "cargo-test",
              "filter": {
                "name": "cargo-test",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUST_VERSION": "stable",
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 30
          }
        ]
      },
      {
        "stageName": "Lint",
        "alias": "CodeQuality",
        "steps": [
          {
            "plugin": {
              "name": "clippy",
              "filter": {
                "name": "clippy",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUST_VERSION": "stable",
                "CLIPPY_FLAGS": "-D warnings"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "rustfmt",
              "filter": {
                "name": "rustfmt",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUST_VERSION": "stable"
              }
            },
            "position": "post"
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "cargo-audit",
              "filter": {
                "name": "cargo-audit",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUST_VERSION": "stable"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post"
          }
        ]
      }
    ]
  }
}
