{
  "project": "rails",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for rails/rails - a full-stack web application framework written in Ruby. Includes RuboCop linting, multi-database testing, security scanning with Brakeman, and gem publishing.",
  "keywords": [
    "ruby",
    "rails",
    "web-framework",
    "mvc",
    "activerecord",
    "full-stack"
  ],
  "accessModifier": "public",
  "props": {
    "project": "rails",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "rails/rails",
          "branch": "main",
          "trigger": "AUTO"
        }
      },
      "plugin": {
        "name": "cdk-synth",
        "filter": {
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        },
        "metadata": {
          "RUBY_VERSION": "3.3"
        }
      }
    },
    "stages": [
      {
        "stageName": "Lint",
        "steps": [
          {
            "plugin": {
              "name": "rubocop",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUBY_VERSION": "3.3",
                "RUBOCOP_CONFIG": ".rubocop.yml"
              }
            },
            "position": "pre",
            "commands": [
              "bundle install",
              "bundle exec rubocop --parallel"
            ]
          }
        ]
      },
      {
        "stageName": "Test-SQLite",
        "steps": [
          {
            "plugin": {
              "name": "rails-test",
              "filter": {
                "version": "1.0.0",
                "imageTag": "ruby-3.3-sqlite",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUBY_VERSION": "3.3",
                "DATABASE_ADAPTER": "sqlite3"
              }
            },
            "position": "pre",
            "timeout": 30,
            "commands": [
              "bundle install",
              "bundle exec rake db:create db:migrate",
              "bundle exec rails test"
            ]
          },
          {
            "plugin": {
              "name": "minitest-coverage",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true
              },
              "metadata": {
                "RUBY_VERSION": "3.3",
                "COVERAGE_THRESHOLD": "70"
              }
            },
            "position": "post",
            "commands": [
              "bundle install",
              "COVERAGE=true bundle exec rails test"
            ]
          }
        ]
      },
      {
        "stageName": "Test-PostgreSQL",
        "steps": [
          {
            "plugin": {
              "name": "rails-test",
              "alias": "rails-test-pg",
              "filter": {
                "version": "1.0.0",
                "imageTag": "ruby-3.3-pg",
                "accessModifier": "public",
                "isActive": true
              },
              "metadata": {
                "RUBY_VERSION": "3.3",
                "DATABASE_ADAPTER": "postgresql",
                "DATABASE_URL": "postgres://localhost:5432/rails_test",
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 40,
            "commands": [
              "bundle install",
              "bundle exec rake db:create db:migrate",
              "bundle exec rails test"
            ]
          },
          {
            "plugin": {
              "name": "rails-test",
              "alias": "rails-test-mysql",
              "filter": {
                "version": "1.0.0",
                "imageTag": "ruby-3.3-mysql",
                "accessModifier": "public",
                "isActive": true
              },
              "metadata": {
                "RUBY_VERSION": "3.3",
                "DATABASE_ADAPTER": "mysql2",
                "DATABASE_URL": "mysql2://localhost:3306/rails_test"
              }
            },
            "position": "post",
            "timeout": 40,
            "failureBehavior": "warn",
            "commands": [
              "bundle install",
              "bundle exec rake db:create db:migrate",
              "bundle exec rails test"
            ]
          }
        ]
      },
      {
        "stageName": "Security",
        "steps": [
          {
            "plugin": {
              "name": "brakeman",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUBY_VERSION": "3.3"
              }
            },
            "position": "pre",
            "commands": [
              "gem install brakeman",
              "brakeman --no-pager -w2"
            ]
          },
          {
            "plugin": {
              "name": "bundler-audit",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true
              },
              "metadata": {
                "RUBY_VERSION": "3.3"
              }
            },
            "position": "pre",
            "failureBehavior": "warn",
            "commands": [
              "gem install bundler-audit",
              "bundle audit check --update"
            ]
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true
              },
              "metadata": {}
            },
            "position": "post",
            "commands": [
              "git secrets --scan"
            ]
          }
        ]
      },
      {
        "stageName": "Publish",
        "steps": [
          {
            "plugin": {
              "name": "gem-publish",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true
              },
              "metadata": {
                "RUBY_VERSION": "3.3",
                "GEM_HOST": "https://rubygems.org"
              }
            },
            "position": "post",
            "commands": [
              "gem push *.gem"
            ]
          }
        ]
      }
    ]
  }
}
