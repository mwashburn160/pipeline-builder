{
  "project": "rails",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for m9rc1n/hello-world-rails - a minimal Rails (Ruby) hello-world app. Includes testing, linting, and security scanning with Brakeman.",
  "keywords": [
    "ruby",
    "rails",
    "backend",
    "web-app"
  ],
  "accessModifier": "public",
  "props": {
    "project": "rails",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "m9rc1n/hello-world-rails",
          "branch": "main",
          "trigger": "NONE"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Test",
        "alias": "UnitTests",
        "steps": [
          {
            "plugin": {
              "name": "rails-test",
              "filter": {
                "name": "rails-test",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUBY_VERSION": "3.4.10",
                "DATABASE_ADAPTER": "sqlite3"
              }
            },
            "position": "pre",
            "timeout": 30
          }
        ]
      },
      {
        "stageName": "Lint",
        "alias": "CodeQuality",
        "steps": [
          {
            "plugin": {
              "name": "rubocop",
              "filter": {
                "name": "rubocop",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUBY_VERSION": "3.4.10",
                "RUBOCOP_CONFIG": ".rubocop.yml"
              }
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "brakeman",
              "filter": {
                "name": "brakeman",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUBY_VERSION": "3.4.10"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "bundler-audit",
              "filter": {
                "name": "bundler-audit",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "RUBY_VERSION": "3.4.10"
              }
            },
            "position": "pre",
            "failureBehavior": "warn"
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post"
          }
        ]
      }
    ]
  }
}
