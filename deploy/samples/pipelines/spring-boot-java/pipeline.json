{
  "project": "spring-boot",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for dstar55/docker-hello-world-spring-boot - a minimal Spring Boot (Java/Maven) hello-world app. Includes building and container packaging.",
  "keywords": [
    "java",
    "spring-boot",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "spring-boot",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "dstar55/docker-hello-world-spring-boot",
          "branch": "master",
          "trigger": "NONE"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "alias": "BuildAndPackage",
        "steps": [
          {
            "plugin": {
              "name": "java",
              "filter": {
                "name": "java-corretto",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "KOTLIN_VERSION": "2.2.21"
              }
            },
            "position": "pre",
            "timeout": 30
          }
        ]
      },
      {
        "stageName": "Package",
        "alias": "PackageImage",
        "steps": [
          {
            "plugin": {
              "name": "docker-build",
              "filter": {
                "name": "docker-build",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "IMAGE_NAME": "spring-boot-acmecorp",
                "IMAGE_TAG": "latest",
                "REGISTRY_TYPE": "none",
                "aws:cdk:codebuild:buildenvironment:privileged": true,
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 20,
            "additionalInputArtifacts": [
              {
                "artifact": {
                  "stageName": "Build",
                  "stageAlias": "BuildAndPackage",
                  "pluginName": "java-corretto",
                  "pluginAlias": "java",
                  "outputDirectory": "**/*"
                },
                "directory": "build-artifact"
              }
            ]
          }
        ]
      }
    ]
  }
}
