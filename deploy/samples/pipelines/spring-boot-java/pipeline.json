{
  "project": "spring-boot",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for spring-projects/spring-boot - an opinionated Java framework for building production-ready applications. Includes building, testing, code quality analysis, security scanning, and Maven artifact publishing.",
  "keywords": [
    "java",
    "spring-boot",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "spring-boot",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "spring-projects/spring-boot",
          "branch": "main",
          "trigger": "AUTO"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "alias": "BuildAndPackage",
        "steps": [
          {
            "plugin": {
              "name": "java",
              "filter": {
                "name": "java-corretto",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "JAVA_VERSION": "25",
                "GRADLE_OPTS": "-Xmx8g -XX:MaxMetaspaceSize=1g"
              }
            },
            "position": "pre",
            "timeout": 30,
            "commands": [
              "./gradlew assemble --no-daemon --parallel"
            ]
          }
        ]
      },
      {
        "stageName": "Test",
        "alias": "UnitTests",
        "steps": [
          {
            "plugin": {
              "name": "jacoco",
              "filter": {
                "name": "jacoco",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "JAVA_VERSION": "17",
                "COVERAGE_THRESHOLD": "70"
              }
            },
            "position": "pre",
            "commands": [
              "./gradlew test jacocoTestReport",
              "./gradlew jacocoTestCoverageVerification"
            ],
            "timeout": 45
          }
        ]
      },
      {
        "stageName": "Lint",
        "alias": "CodeQuality",
        "steps": [
          {
            "plugin": {
              "name": "checkstyle",
              "filter": {
                "name": "checkstyle",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "JAVA_VERSION": "17",
                "CHECKSTYLE_CONFIG": "src/checkstyle/checkstyle.xml"
              }
            },
            "position": "pre",
            "commands": [
              "./gradlew checkstyleMain checkstyleTest"
            ]
          },
          {
            "plugin": {
              "name": "spotbugs",
              "filter": {
                "name": "spotbugs",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "JAVA_VERSION": "17"
              }
            },
            "position": "post",
            "failureBehavior": "warn",
            "commands": [
              "./gradlew spotbugsMain"
            ]
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "semgrep",
              "filter": {
                "name": "semgrep",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "SEMGREP_RULES": "auto",
                "SEMGREP_SEVERITY": "ERROR,WARNING"
              }
            },
            "position": "pre",
            "commands": [
              "semgrep scan --config auto --severity ERROR,WARNING ."
            ]
          },
          {
            "plugin": {
              "name": "dependency-check",
              "filter": {
                "name": "dependency-check",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "JAVA_VERSION": "17",
                "FAIL_ON_CVSS": "7"
              }
            },
            "position": "pre",
            "failureBehavior": "warn",
            "commands": [
              "./gradlew dependencyCheckAnalyze"
            ]
          }
        ]
      },
      {
        "stageName": "Package",
        "alias": "PackageImage",
        "steps": [
          {
            "plugin": {
              "name": "docker-build",
              "filter": {
                "name": "docker-build",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "IMAGE_NAME": "spring-boot-acmecorp",
                "IMAGE_TAG": "latest",
                "REGISTRY_TYPE": "none",
                "aws:cdk:codebuild:buildenvironment:privileged": true,
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 20,
            "additionalInputArtifacts": [
              {
                "artifact": {
                  "stageName": "Build",
                  "stageAlias": "BuildAndPackage",
                  "pluginName": "java-corretto",
                  "pluginAlias": "java",
                  "outputDirectory": "**/*"
                },
                "directory": "build-artifact"
              }
            ]
          }
        ]
      }
    ]
  }
}
