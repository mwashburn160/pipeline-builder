{
  "project": "react",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for facebook/react - a declarative, component-based JavaScript library for building user interfaces. Includes building, testing, linting, security scanning, and package publishing.",
  "keywords": [
    "react",
    "javascript",
    "frontend",
    "ui"
  ],
  "accessModifier": "public",
  "props": {
    "project": "react",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "facebook/react",
          "branch": "main",
          "trigger": "AUTO"
        }
      },
      "plugin": {
        "name": "cdk-synth",
        "filter": {
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        },
        "metadata": {
          "NODE_VERSION": "20"
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "steps": [
          {
            "plugin": {
              "name": "nodejs-bundle",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "NODE_VERSION": "20",
                "BUILD_SCRIPT": "build"
              }
            },
            "position": "pre",
            "timeout": 20,
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn build"
            ]
          },
          {
            "plugin": {
              "name": "typescript-check",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true
              },
              "metadata": {
                "NODE_VERSION": "20"
              }
            },
            "position": "post",
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn tsc --noEmit"
            ]
          }
        ]
      },
      {
        "stageName": "Test",
        "steps": [
          {
            "plugin": {
              "name": "jest",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "NODE_VERSION": "20",
                "JEST_CONFIG": "scripts/jest/config.source.js"
              }
            },
            "position": "pre",
            "timeout": 30,
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn test --ci --maxWorkers=4"
            ]
          }
        ]
      },
      {
        "stageName": "Lint",
        "steps": [
          {
            "plugin": {
              "name": "eslint",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "ESLINT_CONFIG": ".eslintrc.js",
                "NODE_VERSION": "20"
              }
            },
            "position": "pre",
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn lint"
            ]
          },
          {
            "plugin": {
              "name": "prettier",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true
              },
              "metadata": {
                "NODE_VERSION": "20"
              }
            },
            "position": "post",
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn prettier --check ."
            ]
          }
        ]
      },
      {
        "stageName": "Security",
        "steps": [
          {
            "plugin": {
              "name": "npm-audit",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "AUDIT_LEVEL": "high"
              }
            },
            "position": "pre",
            "failureBehavior": "warn",
            "commands": [
              "yarn audit --level high"
            ]
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true
              }
            },
            "position": "post",
            "commands": [
              "git secrets --scan"
            ]
          }
        ]
      },
      {
        "stageName": "Publish",
        "steps": [
          {
            "plugin": {
              "name": "npm-publish",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "NODE_VERSION": "20",
                "NPM_REGISTRY": "https://registry.npmjs.org"
              }
            },
            "position": "pre",
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn build",
              "npm publish --access public"
            ]
          }
        ]
      }
    ]
  }
}
