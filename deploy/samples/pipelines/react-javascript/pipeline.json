{
  "project": "react",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for facebook/react - a declarative, component-based JavaScript library for building user interfaces. Includes building, testing, linting, security scanning, and package publishing.",
  "keywords": [
    "react",
    "javascript",
    "frontend",
    "ui"
  ],
  "accessModifier": "public",
  "props": {
    "project": "react",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "facebook/react",
          "branch": "main",
          "trigger": "AUTO"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "alias": "BuildAndPackage",
        "steps": [
          {
            "plugin": {
              "name": "nodejs-bundle",
              "filter": {
                "name": "nodejs-bundle",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "NODE_VERSION": "20",
                "BUILD_SCRIPT": "build"
              }
            },
            "position": "pre",
            "timeout": 20,
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn build"
            ]
          },
          {
            "plugin": {
              "name": "typescript-check",
              "filter": {
                "name": "typescript-check",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "NODE_VERSION": "20"
              }
            },
            "position": "post",
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn tsc --noEmit"
            ]
          }
        ]
      },
      {
        "stageName": "Test",
        "alias": "UnitTests",
        "steps": [
          {
            "plugin": {
              "name": "jest",
              "filter": {
                "name": "jest",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "NODE_VERSION": "20",
                "JEST_CONFIG": "scripts/jest/config.source.js"
              }
            },
            "position": "pre",
            "timeout": 30,
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn test --ci --maxWorkers=4"
            ]
          }
        ]
      },
      {
        "stageName": "Lint",
        "alias": "CodeQuality",
        "steps": [
          {
            "plugin": {
              "name": "eslint",
              "filter": {
                "name": "eslint",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "ESLINT_CONFIG": ".eslintrc.js",
                "NODE_VERSION": "20"
              }
            },
            "position": "pre",
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn lint"
            ]
          },
          {
            "plugin": {
              "name": "prettier",
              "filter": {
                "name": "prettier",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "NODE_VERSION": "20"
              }
            },
            "position": "post",
            "commands": [
              "yarn install --frozen-lockfile",
              "yarn prettier --check ."
            ]
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "npm-audit",
              "filter": {
                "name": "npm-audit",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "AUDIT_LEVEL": "high"
              }
            },
            "position": "pre",
            "failureBehavior": "warn",
            "commands": [
              "yarn audit --level high"
            ]
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post",
            "commands": [
              "git secrets --scan"
            ]
          }
        ]
      },
      {
        "stageName": "Package",
        "alias": "PackageImage",
        "steps": [
          {
            "plugin": {
              "name": "docker-build",
              "filter": {
                "name": "docker-build",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "IMAGE_NAME": "react-acmecorp",
                "IMAGE_TAG": "latest",
                "REGISTRY_TYPE": "none",
                "aws:cdk:codebuild:buildenvironment:privileged": true,
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 20,
            "additionalInputArtifacts": [
              {
                "artifact": {
                  "stageName": "Build",
                  "stageAlias": "BuildAndPackage",
                  "pluginName": "nodejs-bundle",
                  "pluginAlias": "nodejs-bundle",
                  "outputDirectory": "build-output"
                },
                "directory": "build-artifact"
              }
            ]
          }
        ]
      }
    ]
  }
}
