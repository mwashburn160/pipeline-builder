{
  "project": "react",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for sitek94/vite-deploy-demo - a minimal React (Vite, JavaScript) hello-world app. Includes building and security scanning.",
  "keywords": [
    "react",
    "javascript",
    "frontend",
    "ui"
  ],
  "accessModifier": "public",
  "props": {
    "project": "react",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "sitek94/vite-deploy-demo",
          "branch": "main",
          "trigger": "NONE"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "alias": "BuildAndPackage",
        "steps": [
          {
            "plugin": {
              "name": "nodejs-bundle",
              "filter": {
                "name": "nodejs-bundle",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "NODE_VERSION": "24",
                "BUILD_SCRIPT": "build"
              }
            },
            "position": "pre",
            "timeout": 20
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "npm-audit",
              "filter": {
                "name": "npm-audit",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "AUDIT_LEVEL": "high"
              }
            },
            "position": "pre",
            "failureBehavior": "warn"
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post"
          }
        ]
      }
    ]
  }
}
