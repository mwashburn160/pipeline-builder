{
  "project": "gin",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for gin-gonic/gin - a high-performance HTTP web framework written in Go. Includes building, testing, linting, and security scanning.",
  "keywords": [
    "go",
    "gin",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "gin",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "gin-gonic/gin",
          "branch": "master",
          "trigger": "AUTO"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "alias": "BuildAndPackage",
        "steps": [
          {
            "plugin": {
              "name": "go-compile",
              "filter": {
                "name": "go-compile",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "GO_VERSION": "1.22",
                "CGO_ENABLED": "0",
                "GOOS": "linux",
                "GOARCH": "amd64"
              }
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Test",
        "alias": "UnitTests",
        "steps": [
          {
            "plugin": {
              "name": "go-test",
              "filter": {
                "name": "go-test",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "GO_VERSION": "1.22",
                "GOFLAGS": "-count=1"
              }
            },
            "position": "pre",
            "timeout": 20
          }
        ]
      },
      {
        "stageName": "Lint",
        "alias": "CodeQuality",
        "steps": [
          {
            "plugin": {
              "name": "golangci-lint",
              "filter": {
                "name": "golangci-lint",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "GO_VERSION": "1.22"
              }
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "govulncheck",
              "filter": {
                "name": "govulncheck",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "GO_VERSION": "1.22"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "gosec",
              "filter": {
                "name": "gosec",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "GO_VERSION": "1.22"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post"
          }
        ]
      },
      {
        "stageName": "Package",
        "alias": "PackageImage",
        "steps": [
          {
            "plugin": {
              "name": "docker-build",
              "filter": {
                "name": "docker-build",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "IMAGE_NAME": "gin-acmecorp",
                "IMAGE_TAG": "latest",
                "REGISTRY_TYPE": "none",
                "aws:cdk:codebuild:buildenvironment:privileged": true,
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 20,
            "additionalInputArtifacts": [
              {
                "artifact": {
                  "stageName": "Build",
                  "stageAlias": "BuildAndPackage",
                  "pluginName": "go-compile",
                  "pluginAlias": "go-compile",
                  "outputDirectory": "bin"
                },
                "directory": "build-artifact"
              }
            ]
          }
        ]
      }
    ]
  }
}
