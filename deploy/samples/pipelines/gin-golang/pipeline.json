{
  "project": "gin",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for lamhotsimamora/Hello-World-Golang-Gin - a minimal Gin (Go) hello-world web app. Includes building and security scanning.",
  "keywords": [
    "go",
    "gin",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "gin",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "lamhotsimamora/Hello-World-Golang-Gin",
          "branch": "main",
          "trigger": "NONE"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "alias": "BuildAndPackage",
        "steps": [
          {
            "plugin": {
              "name": "go-compile",
              "filter": {
                "name": "go-compile",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "GO_VERSION": "1.24.13",
                "CGO_ENABLED": "0",
                "GOOS": "linux",
                "GOARCH": "amd64"
              }
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "govulncheck",
              "filter": {
                "name": "govulncheck",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "GO_VERSION": "1.24.13"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "gosec",
              "filter": {
                "name": "gosec",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "GO_VERSION": "1.24.13"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post"
          }
        ]
      }
    ]
  }
}
