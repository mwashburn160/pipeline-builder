{
  "project": "aspnetcore",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for dotnet/aspnetcore - a cross-platform, high-performance framework for building modern cloud-based web applications with .NET. Includes building, testing, code analysis, security scanning, and NuGet publishing.",
  "keywords": [
    "dotnet",
    "csharp",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "aspnetcore",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "dotnet/aspnetcore",
          "branch": "main",
          "trigger": "AUTO"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "alias": "BuildAndPackage",
        "steps": [
          {
            "plugin": {
              "name": "dotnet",
              "filter": {
                "name": "dotnet",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0",
                "aws:cdk:codebuild:buildenvironment:computetype": "LARGE"
              }
            },
            "position": "pre",
            "timeout": 30
          }
        ]
      },
      {
        "stageName": "Test",
        "alias": "UnitTests",
        "steps": [
          {
            "plugin": {
              "name": "dotnet-test",
              "filter": {
                "name": "dotnet-test",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0",
                "aws:cdk:codebuild:buildenvironment:computetype": "LARGE"
              }
            },
            "position": "pre",
            "timeout": 45
          }
        ]
      },
      {
        "stageName": "Lint",
        "alias": "CodeQuality",
        "steps": [
          {
            "plugin": {
              "name": "dotnet-format",
              "filter": {
                "name": "dotnet-format",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "roslyn-analyzers",
              "filter": {
                "name": "roslyn-analyzers",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0",
                "TREAT_WARNINGS_AS_ERRORS": "true"
              }
            },
            "position": "post"
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "dotnet-security-scan",
              "filter": {
                "name": "dotnet-security-scan",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0"
              }
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "trivy",
              "filter": {
                "name": "trivy",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "TRIVY_SEVERITY": "HIGH,CRITICAL"
              }
            },
            "position": "pre",
            "failureBehavior": "warn"
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post"
          }
        ]
      },
      {
        "stageName": "Package",
        "alias": "PackageImage",
        "steps": [
          {
            "plugin": {
              "name": "docker-build",
              "filter": {
                "name": "docker-build",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "IMAGE_NAME": "aspnetcore-acmecorp",
                "IMAGE_TAG": "latest",
                "REGISTRY_TYPE": "none",
                "aws:cdk:codebuild:buildenvironment:privileged": true,
                "aws:cdk:codebuild:buildenvironment:computetype": "MEDIUM"
              }
            },
            "position": "pre",
            "timeout": 20,
            "additionalInputArtifacts": [
              {
                "artifact": {
                  "stageName": "Build",
                  "stageAlias": "BuildAndPackage",
                  "pluginName": "dotnet",
                  "pluginAlias": "dotnet",
                  "outputDirectory": "**/*"
                },
                "directory": "build-artifact"
              }
            ]
          }
        ]
      }
    ]
  }
}
