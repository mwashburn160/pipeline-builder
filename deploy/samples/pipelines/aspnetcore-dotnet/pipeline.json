{
  "project": "aspnetcore",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for dotnet/aspnetcore - a cross-platform, high-performance framework for building modern cloud-based web applications with .NET. Includes building, testing, code analysis, security scanning, and NuGet publishing.",
  "keywords": [
    "dotnet",
    "csharp",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "aspnetcore",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "dotnet/aspnetcore",
          "branch": "main",
          "trigger": "AUTO"
        }
      },
      "plugin": {
        "name": "cdk-synth",
        "filter": {
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        },
        "metadata": {
          "DOTNET_VERSION": "8.0"
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "steps": [
          {
            "plugin": {
              "name": "dotnet-test",
              "filter": {
                "version": "1.0.0",
                "imageTag": "dotnet-8.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0",
                "aws:cdk:codebuild:buildenvironment:computetype": "LARGE"
              }
            },
            "position": "pre",
            "timeout": 30,
            "commands": [
              "dotnet restore",
              "dotnet build --no-restore --configuration Release"
            ]
          },
          {
            "plugin": {
              "name": "docker-build",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0",
                "DOCKERFILE": "Dockerfile",
                "IMAGE_TAG": "latest",
                "aws:cdk:codebuild:buildenvironment:privileged": true
              }
            },
            "position": "post",
            "commands": [
              "docker build -t dotnet/aspnetcore:latest ."
            ]
          }
        ]
      },
      {
        "stageName": "Test",
        "steps": [
          {
            "plugin": {
              "name": "dotnet-test",
              "filter": {
                "version": "1.0.0",
                "imageTag": "dotnet-8.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0",
                "aws:cdk:codebuild:buildenvironment:computetype": "LARGE"
              }
            },
            "position": "pre",
            "timeout": 45,
            "commands": [
              "dotnet test --no-build --configuration Release --logger trx --collect:\"XPlat Code Coverage\""
            ]
          }
        ]
      },
      {
        "stageName": "Lint",
        "steps": [
          {
            "plugin": {
              "name": "dotnet-format",
              "filter": {
                "version": "1.0.0",
                "imageTag": "dotnet-8.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0"
              }
            },
            "position": "pre",
            "commands": [
              "dotnet format --verify-no-changes --verbosity diagnostic"
            ]
          },
          {
            "plugin": {
              "name": "roslyn-analyzers",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0",
                "TREAT_WARNINGS_AS_ERRORS": "true"
              }
            },
            "position": "post",
            "commands": [
              "dotnet build /p:TreatWarningsAsErrors=true /p:EnforceCodeStyleInBuild=true"
            ]
          }
        ]
      },
      {
        "stageName": "Security",
        "steps": [
          {
            "plugin": {
              "name": "dotnet-security-scan",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0"
              }
            },
            "position": "pre",
            "commands": [
              "dotnet tool install --global security-scan",
              "security-scan aspnetcore.sln --excl-proj=*test*"
            ]
          },
          {
            "plugin": {
              "name": "trivy-nodejs",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "TRIVY_SEVERITY": "HIGH,CRITICAL"
              }
            },
            "position": "pre",
            "failureBehavior": "warn",
            "commands": [
              "trivy fs --severity HIGH,CRITICAL ."
            ]
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true
              }
            },
            "position": "post",
            "commands": [
              "git secrets --scan"
            ]
          }
        ]
      },
      {
        "stageName": "Publish",
        "steps": [
          {
            "plugin": {
              "name": "nuget-publish",
              "filter": {
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "8.0",
                "NUGET_SOURCE": "https://api.nuget.org/v3/index.json"
              }
            },
            "position": "pre",
            "commands": [
              "dotnet pack --configuration Release --no-build --output ./nupkg",
              "dotnet nuget push ./nupkg/*.nupkg --source https://api.nuget.org/v3/index.json --skip-duplicate"
            ]
          }
        ]
      }
    ]
  }
}
