{
  "project": "aspnetcore",
  "organization": "AcmeCorp",
  "description": "CI/CD pipeline for Azure-Samples/dotnetcore-docs-hello-world - a minimal ASP.NET Core (net10.0) hello-world web app. Includes building and security scanning.",
  "keywords": [
    "dotnet",
    "csharp",
    "backend",
    "web-api"
  ],
  "accessModifier": "public",
  "props": {
    "project": "aspnetcore",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "Azure-Samples/dotnetcore-docs-hello-world",
          "branch": "main",
          "trigger": "NONE"
        }
      },
      "plugin": {
        "name": "BuildSynth",
        "filter": {
          "name": "cdk-synth",
          "version": "1.0.0",
          "accessModifier": "public",
          "isActive": true,
          "isDefault": true
        }
      }
    },
    "stages": [
      {
        "stageName": "Build",
        "alias": "BuildAndPackage",
        "steps": [
          {
            "plugin": {
              "name": "dotnet",
              "filter": {
                "name": "dotnet",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "10.0",
                "aws:cdk:codebuild:buildenvironment:computetype": "LARGE"
              }
            },
            "position": "pre",
            "timeout": 30
          }
        ]
      },
      {
        "stageName": "Security",
        "alias": "SecurityScan",
        "steps": [
          {
            "plugin": {
              "name": "dotnet-security-scan",
              "filter": {
                "name": "dotnet-security-scan",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "DOTNET_VERSION": "10.0"
              }
            },
            "position": "pre",
            "failureBehavior": "warn"
          },
          {
            "plugin": {
              "name": "trivy",
              "filter": {
                "name": "trivy",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              },
              "metadata": {
                "TRIVY_SEVERITY": "HIGH,CRITICAL"
              }
            },
            "position": "pre",
            "failureBehavior": "warn"
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "version": "1.0.0",
                "accessModifier": "public",
                "isActive": true,
                "isDefault": true
              }
            },
            "position": "post",
            "failureBehavior": "warn"
          }
        ]
      }
    ]
  }
}
