{
  "project": "Fullstack-NodeJS",
  "organization": "AcmeCorp",
  "description": "Full-stack Node.js pipeline: lint, build, test, scan, deploy, verify, and notify.",
  "keywords": [
    "nodejs",
    "eslint",
    "snyk",
    "docker",
    "terraform",
    "slack"
  ],
  "accessModifier": "public",
  "props": {
    "project": "Fullstack-NodeJS",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "defaults": {},
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "acme/fullstack-app",
          "branch": "main",
          "trigger": "WEBHOOK"
        }
      },
      "plugin": {
        "name": "cdk-synth",
        "filter": {
          "name": "cdk-synth",
          "isActive": true,
          "isDefault": true,
          "accessModifier": "public"
        }
      },
      "metadata": {
        "WORKDIR": "./",
        "ENABLE_CACHE": true
      }
    },
    "stages": [
      {
        "stageName": "Lint",
        "steps": [
          {
            "plugin": {
              "name": "eslint",
              "filter": {
                "name": "eslint",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "NODE_VERSION": "22",
              "ESLINT_FORMAT": "stylish",
              "ESLINT_MAX_WARNINGS": "0"
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "prettier",
              "filter": {
                "name": "prettier",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "NODE_VERSION": "22",
              "PRETTIER_GLOB": "src/**/*.{ts,tsx,js,jsx,css,json}"
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Build-Test",
        "steps": [
          {
            "plugin": {
              "name": "nodejs",
              "filter": {
                "name": "nodejs",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "NODE_VERSION": "22",
              "PACKAGE_MANAGER": "auto"
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Security",
        "steps": [
          {
            "plugin": {
              "name": "snyk",
              "filter": {
                "name": "snyk",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "LANGUAGE": "node",
              "LANGUAGE_VERSION": "22"
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "SCAN_MODE": "detect"
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Package",
        "steps": [
          {
            "plugin": {
              "name": "docker-build",
              "filter": {
                "name": "docker-build",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "REGISTRY_TYPE": "ecr",
              "IMAGE_NAME": "fullstack-app",
              "IMAGE_TAG": "latest"
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Deploy",
        "steps": [
          {
            "plugin": {
              "name": "terraform",
              "filter": {
                "name": "terraform",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "TF_VERSION": "1.9.8",
              "TF_WORKING_DIR": "infra/",
              "TF_ACTION": "apply",
              "TF_AUTO_APPROVE": "true"
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Verify",
        "steps": [
          {
            "plugin": {
              "name": "health-check",
              "filter": {
                "name": "health-check",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "HEALTH_ENDPOINTS": "https://api.example.com/health,https://app.example.com",
              "HEALTH_RETRIES": "5",
              "EXPECTED_STATUS": "200"
            },
            "position": "post"
          }
        ]
      },
      {
        "stageName": "Notify",
        "steps": [
          {
            "plugin": {
              "name": "slack-notify",
              "filter": {
                "name": "slack-notify",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "NOTIFICATION_TYPE": "pipeline_status",
              "PIPELINE_NAME": "Fullstack-NodeJS",
              "MENTION_ON_FAILURE": "@oncall"
            },
            "position": "post"
          }
        ]
      }
    ]
  }
}
