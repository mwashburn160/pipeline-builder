{
  "project": "Sample",
  "organization": "AcmeCorp",
  "description": "A sample pipeline for demonstration purposes.",
  "keywords": [
    "python",
    "pytest",
    "codebuild"
  ],
  "accessModifier": "public",
  "props": {
    "project": "Sample",
    "organization": "AcmeCorp",
    "pipelineName": "SamplePipeline",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "defaults": {},
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "Pytest-with-Eric/pytest-logging-example",
          "branch": "main",
          "trigger": "NONE"
        }
      },
      "plugin": {
        "name": "cdk-synth",
        "filter": {
          "name": "cdk-synth",
          "isActive": true,
          "isDefault": true,
          "accessModifier": "public"
        }
      },
      "metadata": {
        "WORKDIR": "./",
        "ENABLE_CACHE": true
      }
    },
    "stages": [
      {
        "stageName": "Test",
        "steps": [
          {
            "plugin": {
              "name": "python-pytest",
              "filter": {
                "name": "python-pytest",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "PYTHON_VERSION": "3.12"
            },
            "position": "pre"
          }
        ]
      }
    ]
  }
}