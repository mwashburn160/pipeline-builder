{
  "project": "Security-Scan",
  "organization": "AcmeCorp",
  "description": "Comprehensive security scanning pipeline: secret detection, SAST, SCA, container scanning, and license compliance.",
  "keywords": [
    "security",
    "sast",
    "sca",
    "secrets",
    "container",
    "license"
  ],
  "accessModifier": "public",
  "props": {
    "project": "Security-Scan",
    "organization": "AcmeCorp",
    "global": {
      "aws:cdk:pipelines:codepipeline:selfmutation": true,
      "aws:cdk:pipelines:codepipeline:dockerenabledforselfmutation": true,
      "aws:cdk:pipelines:codepipeline:publishassetsinparallel": true,
      "aws:cdk:pipelines:codepipeline:crossaccountkeys": true,
      "aws:cdk:pipelines:codepipeline:enablekeyrotation": true,
      "aws:cdk:pipelines:codepipeline:reusecrossregionsupportstacks": true,
      "aws:cdk:pipelines:codepipeline:usechangesets": false
    },
    "defaults": {},
    "synth": {
      "source": {
        "type": "github",
        "options": {
          "repo": "acme/microservice",
          "branch": "main",
          "trigger": "WEBHOOK"
        }
      },
      "plugin": {
        "name": "cdk-synth",
        "filter": {
          "name": "cdk-synth",
          "isActive": true,
          "isDefault": true,
          "accessModifier": "public"
        }
      },
      "metadata": {
        "WORKDIR": "./"
      }
    },
    "stages": [
      {
        "stageName": "Secret-Detection",
        "steps": [
          {
            "plugin": {
              "name": "git-secrets",
              "filter": {
                "name": "git-secrets",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "SCAN_MODE": "detect",
              "REPORT_FORMAT": "json"
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Static-Analysis",
        "steps": [
          {
            "plugin": {
              "name": "trivy",
              "filter": {
                "name": "trivy",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "TRIVY_SEVERITY": "CRITICAL,HIGH",
              "TRIVY_FORMAT": "json"
            },
            "position": "pre"
          },
          {
            "plugin": {
              "name": "snyk",
              "filter": {
                "name": "snyk",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "LANGUAGE": "node",
              "LANGUAGE_VERSION": "22"
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Dependency-Scan",
        "steps": [
          {
            "plugin": {
              "name": "dependency-check",
              "filter": {
                "name": "dependency-check",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "DC_FAIL_ON_CVSS": "7",
              "DC_FORMAT": "JSON"
            },
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "Container-Scan",
        "steps": [
          {
            "plugin": {
              "name": "docker-lint",
              "filter": {
                "name": "docker-lint",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {},
            "position": "pre"
          }
        ]
      },
      {
        "stageName": "License-Check",
        "steps": [
          {
            "plugin": {
              "name": "license-checker",
              "filter": {
                "name": "license-checker",
                "isActive": true,
                "isDefault": true,
                "accessModifier": "public"
              }
            },
            "metadata": {
              "LICENSE_DENY": "GPL-3.0,AGPL-3.0"
            },
            "position": "pre"
          }
        ]
      }
    ]
  }
}
