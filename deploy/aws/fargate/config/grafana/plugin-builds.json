{
  "title": "Plugin Builds",
  "uid": "plugin-builds",
  "version": 1,
  "schemaVersion": 39,
  "timezone": "browser",
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "15s",
  "editable": true,
  "tags": ["plugin", "builds", "docker"],
  "annotations": { "list": [] },
  "links": [],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Builds Completed",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "refId": "A", "expr": "count_over_time({service=\"plugin\"} |= `Plugin build completed` [1h])" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Builds Failed",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "refId": "A", "expr": "count_over_time({service=\"plugin\"} |= `Plugin build failed` [1h])" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Builds Queued",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "refId": "A", "expr": "count_over_time({service=\"plugin\"} |= `Build queued` [1h])" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Worker Status",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [{ "refId": "A", "expr": "count_over_time({service=\"plugin\"} |= `Plugin build worker ready` [5m])" }],
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }, { "type": "range", "options": { "from": 1, "to": 9999, "result": { "text": "READY", "color": "green" } } }] }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Build Success vs Failure",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "count_over_time({service=\"plugin\"} |= `Plugin build completed` [5m])", "legendFormat": "Completed" },
        { "refId": "B", "expr": "count_over_time({service=\"plugin\"} |= `Plugin build failed` [5m])", "legendFormat": "Failed" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Completed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Build Queue Activity",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "count_over_time({service=\"plugin\"} |= `Build queued` [5m])", "legendFormat": "Queued" },
        { "refId": "B", "expr": "count_over_time({service=\"plugin\"} |= `Building image` [5m])", "legendFormat": "Building" },
        { "refId": "C", "expr": "count_over_time({service=\"plugin\"} |= `Image pushed` [5m])", "legendFormat": "Pushed" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Docker Layer Activity",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "count_over_time({service=\"plugin\"} |= `Layer already exists` [5m])", "legendFormat": "Cached Layers" },
        { "refId": "B", "expr": "count_over_time({service=\"plugin\"} |= `Pushed` [5m])", "legendFormat": "New Layers" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DinD Container Activity",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "count_over_time({container=\"plugin-dind\"} |~ `level=info` [5m])", "legendFormat": "DinD Events" },
        { "refId": "B", "expr": "count_over_time({container=\"plugin-dind\"} |~ `level=error|level=warning` [5m])", "legendFormat": "DinD Errors" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Build Logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "{service=\"plugin\"} |~ `build|Build|queued|image|pushed|failed`" }
      ],
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending" }
    }
  ]
}
