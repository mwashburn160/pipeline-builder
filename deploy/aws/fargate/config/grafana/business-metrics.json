{
  "title": "Business Metrics",
  "uid": "business-metrics",
  "version": 1,
  "schemaVersion": 39,
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "editable": true,
  "tags": ["business", "usage"],
  "annotations": { "list": [] },
  "links": [],
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pipelines Created (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "increase(http_requests_total{service=\"pipeline\", method=\"POST\", route=\"/pipelines\", status_code=\"201\"}[24h])" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Plugins Uploaded (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "increase(http_requests_total{service=\"plugin\", method=\"POST\", route=\"/plugins/upload\", status_code=\"202\"}[24h])" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "AI Generations (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "increase(http_requests_total{service=~\"pipeline|plugin\", route=~\"/pipelines/generate.*|/plugins/generate.*\", method=\"POST\"}[24h])" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "API Calls (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "refId": "A", "expr": "sum(increase(http_requests_total[24h]))" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" }, "unit": "short", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pipeline & Plugin Creates Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "increase(http_requests_total{service=\"pipeline\", method=\"POST\", route=\"/pipelines\", status_code=\"201\"}[1h])", "legendFormat": "Pipelines Created" },
        { "refId": "B", "expr": "increase(http_requests_total{service=\"plugin\", method=\"POST\", route=\"/plugins/upload\", status_code=\"202\"}[1h])", "legendFormat": "Plugins Uploaded" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "AI Generation Requests",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (status_code) (rate(http_requests_total{route=~\"/pipelines/generate.*|/plugins/generate.*\", method=\"POST\"}[5m]))", "legendFormat": "{{status_code}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15 }, "unit": "reqps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "User Registrations & Logins",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "refId": "A", "expr": "count_over_time({service=\"platform\"} |= `User registered` [1h])", "legendFormat": "Registrations" },
        { "refId": "B", "expr": "count_over_time({service=\"platform\"} |= `Login successful` [1h])", "legendFormat": "Logins" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Service Traffic Distribution",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum by (service) (rate(http_requests_total[5m]))", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "percent" } }, "unit": "reqps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } }
    }
  ]
}
