# =============================================================================
# Pipeline Builder - AWS Fargate Deployment Configuration
# =============================================================================
# This file documents the environment variables used across the Fargate
# deployment. Secrets are stored in AWS Secrets Manager (pipeline-builder/app-secrets)
# and injected into containers automatically. This file is for REFERENCE only.
#
# To deploy# 1. Run bin/init-secrets.sh to generate and store secrets
# 2. Run bin/setup.sh to deploy all CloudFormation stacks
#
# The deployment uses the ALB DNS name (CNAME) directly  no custom domain
# or certificate management required.
# =============================================================================

# =============================================================================
# Deployment Configuration (passed to setup.sh)
# =============================================================================

# AWS Region
AWS_REGION=us-east-1

# CloudFormation stack name prefix
STACK_PREFIX=pb

# Deployment posture (read by setup.sh; passed to the foundation + services
# stacks). Choose ONE:
#   private = inside-AWS-only: internal-scheme ALB in private subnets, and the
#              pipeline service synthesizes VPC-attached CodeBuild projects
#              (PIPELINE_VPC_ID/SUBNET_IDS wired from the foundation VPC). The
#              foundation creates a Route53 PRIVATE zone aliasing DOMAIN to the
#              internal ALB + the VPC interface endpoints. (default)
#   public   = internet-facing ALB in public subnets; AWS CodeBuild reaches the
#              gateway over the internet via a public Route53 alias.
# TLS is a DNS-validated ACM cert the foundation requests for DOMAIN against
# HOSTED_ZONE_ID (publicly trusted, so CodeBuild trusts the gateway) — no
# self-signed step. DOMAIN + HOSTED_ZONE_ID are REQUIRED in both modes.
DEPLOY_MODE=private

# GHCR credentials. The ghcr.io/mwashburn160/* images are PUBLIC (anonymous
# pulls work), but GitHub rate-limits anonymous pulls at 60 req/hr per IP
# which trips mid-deploy when Fargate fans out 9 service-image pulls.
# Providing your own PAT raises the ceiling to 5,000 req/hr.
#
# Use YOUR OWN GitHub Personal Access Token  never copy a value from
# documentation, an example, or another user's deploy.
# - Generate at https://github.com/settings/tokens (Classic, scope: read:packages)
# or https://github.com/settings/personal-access-tokens (Fine-grained,
# account permission: Packages: Read).
# ghcr.io validates only the token for PAT auth; the username is the fixed image
# owner (init-secrets.sh uses a constant), so there is nothing to set here.
GHCR_USER=mwashburn160
GHCR_TOKEN=ghp_replace_with_your_own_pat

# =============================================================================
# Container Images (override defaults in 04-services.yaml)
# =============================================================================

PLATFORM_IMAGE=ghcr.io/mwashburn160/platform:3.4.97
PIPELINE_IMAGE=ghcr.io/mwashburn160/pipeline:3.4.87
PLUGIN_IMAGE=ghcr.io/mwashburn160/plugin:3.4.92
QUOTA_IMAGE=ghcr.io/mwashburn160/quota:3.4.87
BILLING_IMAGE=ghcr.io/mwashburn160/billing:3.4.87
MESSAGE_IMAGE=ghcr.io/mwashburn160/message:3.4.88
REPORTING_IMAGE=ghcr.io/mwashburn160/reporting:3.4.87
COMPLIANCE_IMAGE=ghcr.io/mwashburn160/compliance:3.4.89
IMAGE_REGISTRY_IMAGE=ghcr.io/mwashburn160/image-registry:3.4.92
FRONTEND_IMAGE=ghcr.io/mwashburn160/frontend:3.4.102

# =============================================================================
# Secrets Manager Values (auto-generated by init-secrets.sh)
# =============================================================================
# These are stored in AWS Secrets Manager at "pipeline-builder/app-secrets"
# and injected into ECS task definitions automatically.
# Listed here for reference only  do NOT set these manually.
#
# JWT_SECRET=<auto-generated>
# REFRESH_TOKEN_SECRET=<auto-generated>
# =============================================================================
# Multi-tenant Security
# =============================================================================
# Read-replica primitive (opt-in). When DB_REPLICA_HOST is set, callers
# that import `dbReplica` from pipeline-data route through this replica.
# Writes / transactions MUST stay on the primary. RDS read replicas /
# Aurora reader endpoints are the typical Fargate-side targets.
# DB_REPLICA_HOST=pipeline-builder-reader.cluster-ro-xxx.us-east-1.rds.amazonaws.com
# DB_REPLICA_PORT=5432
# DB_REPLICA_MAX_POOL=20

# Behavior when withTenantTx is called outside any tenant scope. Production
# Fargate deploys: flip to 'strict' after the staging environment soak shows
# zero spurious warnings for >7 days.
#   warn   (default) — log a stack-traced warning, transaction still runs.
#   strict           — throw immediately. Recommended for production.
RLS_CONTEXT_MODE=warn

# Bootstrap super-admins on platform startup. Comma-separated user emails;
# accounts matching these emails are auto-promoted to isSuperAdmin=true at
# boot. Required for fresh installs (otherwise no one can administer).
BOOTSTRAP_SUPERADMIN_EMAILS=admin@internal

# Per-org KMS key wrapping for AI provider keys + IdP secrets. Recommended
# for SOC2/FedRAMP deploys (per-org KMS CMKs limit blast radius). Each org's
# CMK config lives in Organization.kmsConfig; orgs without an entry use the
# shared SECRET_ENCRYPTION_KEY master.
# SECRET_ENCRYPTION_PER_ORG_KMS=false

# Per-tier access-token TTL overrides (seconds). Compliance-driven
# enterprise tiers typically want SHORTER TTLs.
# JWT_EXPIRES_IN_DEVELOPER=7200
# JWT_EXPIRES_IN_PRO=3600
# JWT_EXPIRES_IN_UNLIMITED=1800

# Per-tier BullMQ Redis DB partitioning. ElastiCache Redis (single-node /
# replication group) supports db=0-15; ElastiCache Cluster mode forces 0.
# REDIS_DB_DEVELOPER=0
# REDIS_DB_PRO=1
# REDIS_DB_UNLIMITED=2

# Per-org HTTP request metric sampling (range [0.0, 1.0]).
# HTTP_METRICS_ORG_SAMPLE_RATE=1.0

# Per-org SSE connection ceiling. Default 50.
# SSE_MAX_CLIENTS_PER_ORG=50

# =============================================================================
# Service Discovery (Cloud Map - auto-configured)
# =============================================================================
# All services register in the pipeline-builder.local private DNS namespace.
# These hostnames are set automatically in ECS task definitions.
#
# DB_HOST=pgbouncer.pipeline-builder.local
# REDIS_HOST=redis.pipeline-builder.local
# QUOTA_SERVICE_HOST=quota.pipeline-builder.local
# BILLING_SERVICE_HOST=billing.pipeline-builder.local
LOKI_URL=http://loki.pipeline-builder.local:3100
PROMETHEUS_URL=http://prometheus.pipeline-builder.local:9090
# IMAGE_REGISTRY_HOST=registry.pipeline-builder.local
#
# Out-of-cluster plugin-image pulls (AWS CodeBuild): the pipeline service's
# IMAGE_REGISTRY_PULL_HOST is set in the ECS task definition to !Ref DomainName
# (the ALB gateway), since CodeBuild can't resolve the in-cluster
# registry.pipeline-builder.local. Pulls flow through nginx's /v2/ route, and
# nginx rewrites the registry's Bearer realm to the public token endpoint
# (registry-auth.js). The ALB's DNS-validated ACM cert is publicly trusted, so
# CodeBuild's x509 verification passes (public mode over the internet; private
# mode via the in-stack private zone to the internal ALB).

# =============================================================================
# Application Environment (set in ECS task definitions)
# =============================================================================
# These are configured directly in the CloudFormation templates.
# Override by modifying the stack parameters or task definitions.
#
# PORT=3000
# TRUST_PROXY=1
# LOG_LEVEL=info
# LOG_FORMAT=json
# DB_PORT=6432
# DATABASE=pipeline_builder
# REDIS_PORT=6379
# QUOTA_SERVICE_PORT=3000
# BILLING_SERVICE_PORT=3000
# BILLING_ENABLED=false
# BILLING_PROVIDER=stub
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# LAMBDA_RUNTIME=nodejs24.x

# =============================================================================
# Message Routing
# =============================================================================
# Comma-separated email-like aliases that resolve to the system org
# SUPPORT_ALIASES=support@pipeline-builder,help@pipeline-builder

# =============================================================================
# Transactional email (SES)
# =============================================================================
# Email is NOT configured via this file on Fargate — the platform's env comes
# from the CloudFormation task definition (stacks/04-services.yaml). SES is
# provisioned BY DEFAULT; pass --no-email to skip it:
#
#   bash bin/setup.sh --domain ... --hosted-zone-id ...            # SES on (default)
#   bash bin/setup.sh --domain ... --hosted-zone-id ... --no-email # SES off
#
# By default this provisions the SES identity + DKIM (01-foundation), grants the task role
# ses:SendEmail (02-cluster), and sets EMAIL_ENABLED=true / EMAIL_PROVIDER=ses /
# SES_REGION=<stack region> / EMAIL_FROM=noreply@<domain> on the platform task.
# Override the sender with --email-from / --email-from-name; reuse an already-
# verified domain with --no-create-ses-identity. Credentials come from the task
# role (no access keys). New SES accounts are sandboxed until you request
# production access.
#
# Every send routes through an SES configuration set wired to an SNS topic
# (<prefix>-email-events) that receives bounces/complaints — pass
# --alert-email you@example.com to be notified before SES throttles the account.

# =============================================================================
# Optional Overrides
# =============================================================================
# These can be added to the ECS task definitions if needed#
# OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
# OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key
# XAI_API_KEY=your-xai-api-key
#
# HTTP Client
# HTTP_CLIENT_TIMEOUT=5000
# HTTP_CLIENT_MAX_RETRIES=2
# HTTP_CLIENT_RETRY_DELAY_MS=200
#
# SSE (Server-Sent Events)
# SSE_MAX_CLIENTS_PER_REQUEST=10
# SSE_CLIENT_TIMEOUT_MS=1800000
# SSE_CLEANUP_INTERVAL_MS=300000
#
# Plugin Build Queue
# PLUGIN_BUILD_QUEUE_NAME=plugin-build
# PLUGIN_BUILD_MAX_ATTEMPTS=2
# PLUGIN_BUILD_BACKOFF_DELAY_MS=5000
# PLUGIN_BUILD_COMPLETED_RETENTION_SECS=3600
# PLUGIN_BUILD_FAILED_RETENTION_SECS=86400
# PLUGIN_BUILD_WORKER_TIMEOUT_MS=10000
# PLUGIN_DLQ_MAX_ATTEMPTS=3
# PLUGIN_DLQ_BACKOFF_BASE_MS=300000
# PLUGIN_DLQ_MAX_SIZE=20
#
# Docker Build (rootless buildkitd sidecar; no strategy switch)
BUILDKIT_HOST=unix:///run/buildkit/buildkitd.sock
# Docker build timeout in milliseconds (default: 900000 = 15 min)
DOCKER_BUILD_TIMEOUT_MS=900000
# DOCKER_PUSH_TIMEOUT_MS=300000
# PLUGIN_UPLOAD_TIMEOUT_MS=300000
# PLUGIN_MAX_UPLOAD_MB=1024
#
# Plugin build strategy: build_image (default) or prebuilt
# (consumed by deploy/bin/init-platform.sh when loading the plugin catalog)
# PLUGIN_BUILD_STRATEGY=build_image
#
# Plugin storage paths. Container runs with readOnlyRootFilesystem=true so
# both MUST be absolute paths matching EFS access-point ContainerPath in
# 04-services.yaml. Defaults set in task definition for the plugin service.
# DOCKER_BUILD_TEMP_ROOT=/opt/pipeline/pipeline-data/plugins-data/builds
# PLUGIN_UPLOAD_DIR=/opt/pipeline/pipeline-data/plugins-data/uploads
#
# Pagination & Limits
# MAX_PAGE_LIMIT=1000
# DEFAULT_PAGE_LIMIT=100
# MAX_PROMPT_LENGTH=5000
# MAX_PLUGIN_UPLOAD_BYTES=104857600
# PIPELINE_NAME_MAX_LENGTH=100
# DEFAULT_PLUGIN_VERSION=1.0.0
#
# Database Connection Retries
# DB_MAX_RETRIES=3
# DB_RETRY_DELAY_MS=1000
#
# Cookie & OAuth
# COOKIE_SAME_SITE=lax
# GOOGLE_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
# GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
# GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v2/userinfo
# OAUTH_CLEANUP_INTERVAL_MS=60000
#
# Platform Log & Pagination
# LOG_DEFAULT_LIMIT=100
# LOG_MAX_LIMIT=1000
# LOG_DEFAULT_LOOKBACK_MS=3600000
# PLATFORM_LIST_MAX=100
# PLATFORM_LIST_DEFAULT=20
#
# Git URL Analysis
# GITHUB_API_BASE_URL=https://api.github.com
# BITBUCKET_API_BASE_URL=https://api.bitbucket.org/2.0
#
# AI Generation SSE
# SSE_STREAM_TIMEOUT_MS=300000
#
# Plugin Service Discovery (auto-plugin creation)
# PLUGIN_SERVICE_HOST=plugin.pipeline-builder.local
# PLUGIN_SERVICE_PORT=3000
#
# Pipeline Service Discovery
# PIPELINE_SERVICE_HOST=pipeline.pipeline-builder.local
# PIPELINE_SERVICE_PORT=3000
#
# Message Service Discovery (WebSocket messaging)
# MESSAGE_SERVICE_HOST=message.pipeline-builder.local
# MESSAGE_SERVICE_PORT=3000
#
# Compliance Service
# COMPLIANCE_SERVICE_HOST=compliance.pipeline-builder.local
# COMPLIANCE_SERVICE_PORT=3000
# COMPLIANCE_BYPASS=false
# SCAN_SCHEDULER_INTERVAL_MS=60000
#
# Plugin Build Temp
# TEMP_DIR_MAX_AGE_MS=14400000

# =============================================================================
# Reporting & Audit
# =============================================================================
# AUDIT_RETENTION_DAYS=90
# EVENT_RETENTION_DAYS=90

# =============================================================================
# Response Compression
# =============================================================================
# Minimum response size in bytes before gzip compression is applied (default: 1024)
# COMPRESSION_THRESHOLD_BYTES=1024

# =============================================================================
# Idempotency Configuration
# =============================================================================
# TTL for cached idempotent responses in milliseconds (default: 300000 = 5 minutes)
# IDEMPOTENCY_TTL_MS=300000

# Maximum number of idempotent responses stored in memory (default: 10000)
# IDEMPOTENCY_MAX_STORE_SIZE=10000

# Cleanup interval for expired idempotency entries in ms (default: 60000 = 1 minute)
# IDEMPOTENCY_CLEANUP_INTERVAL_MS=60000

# =============================================================================
# Cache Configuration
# =============================================================================
# In-memory cache cleanup interval in milliseconds (default: 30000 = 30 seconds)
# CACHE_CLEANUP_INTERVAL_MS=30000

# =============================================================================
# SSE Backpressure
# =============================================================================
# Number of consecutive write failures before disconnecting slow SSE clients (default: 10)
# SSE_BACKPRESSURE_THRESHOLD=10

# =============================================================================
# HTTP Cache-Control Headers
# =============================================================================
# Cache-Control header for list/filter endpoints (default: private, max-age=30, stale-while-revalidate=60)
# CACHE_CONTROL_LIST=private, max-age=30, stale-while-revalidate=60

# Cache-Control header for detail endpoints (default: private, max-age=60, stale-while-revalidate=120)
# CACHE_CONTROL_DETAIL=private, max-age=60, stale-while-revalidate=120

# =============================================================================
# OpenTelemetry Tracing
# =============================================================================
# On Fargate, tracing is wired through CloudFormation, NOT this .env — the
# platform task definition (stacks/04-services.yaml) sets OTEL_TRACING_ENABLED
# (from the OtelTracingEnabled stack parameter, default "true") and points the
# exporter at the in-cluster Jaeger collector
# (stacks/05-observability.yaml → jaeger.pipeline-builder.local:4318). To
# disable, deploy with OtelTracingEnabled=false. These keys are documentation
# only here; setting them in .env has no effect on the ECS task env.
#   OTEL_TRACING_ENABLED=true
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger.pipeline-builder.local:4318/v1/traces

# =============================================================================
# Service Tunables  added by the hard-coded-values refactor
# =============================================================================
# Every value below has a sensible default baked into the code; set only when
# you need to deviate. Grouped by service for easy targeting.

# --- Platform ---------------------------------------------------------------
# Timeout for Alertmanager API calls (default: 5000)
# ALERTMANAGER_TIMEOUT_MS=5000
# Platform org/user count scraper interval (default: 60000)
# PLATFORM_SCRAPER_INTERVAL_MS=60000
# Per-destination delivery timeout from the alertmanager-relay (default: 5000)
# ALERT_DELIVERY_TIMEOUT_MS=5000
# Email verification token TTL (default: 86400000 = 24h)
# AUTH_VERIFICATION_TOKEN_TTL_MS=86400000
# Max in-memory OAuth state map size (default: 1000)
# OAUTH_MAX_PENDING_STATES=1000
# Dashboard field caps (defaults: name=150, description=1000, panel title=200, panels=50)
# DASHBOARD_MAX_NAME=150
# DASHBOARD_MAX_DESCRIPTION=1000
# DASHBOARD_MAX_PANEL_TITLE=200
# DASHBOARD_MAX_PANELS=50
# Alert destination field caps (defaults: label=100, target URL=2048)
# ALERT_DESTINATION_MAX_LABEL=100
# ALERT_DESTINATION_MAX_TARGET=2048
# org-cascade HTTP timeout to quota/billing (default: 5000)
# ORG_CASCADE_HTTP_TIMEOUT_MS=5000

# --- Plugin -----------------------------------------------------------------
# per-tier worker queue cache TTL  how long the worker caches an
# org's tier before re-fetching from the quota service (default: 300000 = 5min)
# PLUGIN_TIER_CACHE_TTL_MS=300000
# Per-org build slot TTL (default: 900 seconds)
# PLUGIN_ORG_SLOT_TTL_SEC=900
# Queue-metrics scraper interval (default: 15000)
# PLUGIN_QUEUE_METRICS_INTERVAL_MS=15000

# --- Pipeline ---------------------------------------------------------------
# Timeout for pipeline → plugin service calls (default: 30000)
# PIPELINE_PLUGIN_SERVICE_TIMEOUT_MS=30000

# --- Image Registry ---------------------------------------------------------
# Read timeout for blob streaming (default: 30000)
# REGISTRY_BLOB_STREAM_TIMEOUT_MS=30000
# Storage-rollup cache TTL (default: 60000)
# REGISTRY_STORAGE_CACHE_TTL_MS=60000
# Blob proxy size cap (default: 5242880 = 5 MB)
# REGISTRY_MAX_BLOB_PROXY_BYTES=5242880
# Cross-repo copy parallelism (defaults: children=3, blobs=8)
# REGISTRY_COPY_PARALLEL_CHILDREN=3
# REGISTRY_COPY_PARALLEL_BLOBS=8

# --- Compliance -------------------------------------------------------------
# Cap on user-supplied regex patterns (default: 200)
# COMPLIANCE_MAX_REGEX_LENGTH=200
# Compliance validate-attribute caps (defaults: keys=100, depth=5)
# COMPLIANCE_MAX_ATTRIBUTE_KEYS=100
# COMPLIANCE_MAX_ATTRIBUTE_DEPTH=10
# Scan executor progress batch size (default: 10)
# COMPLIANCE_SCAN_PROGRESS_BATCH_SIZE=10

# --- Billing ----------------------------------------------------------------
# cost-attribution fallback window for orgs with no active sub (default: 30 days)
# BILLING_USAGE_FALLBACK_DAYS=30

# --- Quota ------------------------------------------------------------------
# TTL for the GET /quotas/at-risk computation cache (default: 60000 = 60s).
# Raise on large fleets to reduce per-org quota recomputation cost; lower for
# fresher operator dashboards.
# QUOTA_AT_RISK_CACHE_TTL_MS=60000

# --- Message (SSE notifications) --------------------------------------------
# Hard cap on total live SSE tickets across the message process; bounds
# memory under abuse (default: 1000).
# SSE_MAX_TOTAL_TICKETS=1000
# Per-org cap on live SSE tickets; prevents a single tenant from
# saturating the ticket table (default: 10).
# SSE_MAX_TICKETS_PER_ORG=10

# --- Secret Encryption ------------------------------------------------
# 32-byte master key for AES-256-GCM envelope encryption of secret columns
# (aiProviderKeys, IdP client secrets). Accepts hex (64 chars) or base64
# (44 chars). When unset, secrets are stored in clear text with a warning 
# acceptable for dev, MUST be set for any env handling real customer creds.
# Generate with: openssl rand -hex 32
# SECRET_ENCRYPTION_KEY=

# --- buildkitd --------------------------------------------------------
# All deploys ship a single shared `buildkitd` container co-located
# with the plugin task. Tier partitioning lives at the BullMQ queue
# level inside the plugin service (developer / pro / unlimited
# queues); every tier's worker dispatches to the same buildkitd via
# the unix socket set on BUILDKIT_HOST in 04-services.yaml. Operators
# who want kernel-namespace isolation per tier can restore standalone
# ECS services and set PLUGIN_BUILDKIT_ADDR_<TIER>; see
# docker-build.ts for details.
